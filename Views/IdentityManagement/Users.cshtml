@using BloodDonorProject.Models.ViewModel
@model List<UserWithRolesVIewModel>
@{
    ViewData["Title"] = "Users & Roles";
}

@Html.AntiForgeryToken()

<div class="page-header mb-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h2 class="page-title mb-1">
                <i class="bi bi-people-fill me-2 text-danger"></i>Users & Roles
            </h2>
            <p class="text-muted mb-0">Manage system users and their assigned roles</p>
        </div>
        <span class="badge bg-danger-subtle text-danger fs-6 px-3 py-2 rounded-pill">
            <i class="bi bi-person-check me-1"></i>@Model.Count user@(Model.Count != 1 ? "s" : "")
        </span>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="bi bi-check-circle-fill flex-shrink-0"></i>
        <span>@TempData["Success"]</span>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
        <span>@TempData["Error"]</span>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Toast notification -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1100">
    <div id="deleteToast" class="toast align-items-center border-0" role="alert" aria-live="assertive">
        <div class="d-flex">
            <div class="toast-body d-flex align-items-center gap-2" id="toastBody"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white border-bottom py-3">
        <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
            <h5 class="mb-0 fw-semibold">All Users</h5>
            <div class="input-group" style="max-width: 280px;">
                <span class="input-group-text bg-light border-end-0">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" id="userSearch" class="form-control bg-light border-start-0 ps-0"
                       placeholder="Search users..." oninput="filterUsers(this.value)" />
            </div>
        </div>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-people display-4 text-muted"></i>
                <p class="text-muted mt-3 mb-0">No users found</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="usersTable">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3 fw-semibold text-muted small text-uppercase">User</th>
                            <th class="py-3 fw-semibold text-muted small text-uppercase">Roles</th>
                            <th class="py-3 pe-4 fw-semibold text-muted small text-uppercase text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="usersBody">
                        @foreach (var user in Model)
                        {
                            <tr class="user-row" id="row-@user.UserId">
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="avatar-circle bg-danger-subtle text-danger">
                                            @user.Email.Substring(0, 1).ToUpper()
                                        </div>
                                        <div class="fw-semibold">@user.Email</div>
                                    </div>
                                </td>
                                <td class="py-3">
                                    @if (user.Roles.Any())
                                    {
                                        @foreach (var role in user.Roles)
                                        {
                                            <span class="badge rounded-pill bg-primary-subtle text-primary me-1">@role</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small fst-italic">No roles assigned</span>
                                    }
                                </td>
                                <td class="py-3 pe-4 text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a asp-action="ManageUserRoles" asp-route-userId="@user.UserId"
                                           class="btn btn-sm btn-outline-primary px-3">
                                            <i class="bi bi-shield-lock me-1"></i>Manage Roles
                                        </a>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger px-3 delete-btn"
                                                data-user-id="@user.UserId"
                                                data-user-email="@user.Email">
                                            <i class="bi bi-trash3 me-1"></i>Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <div class="delete-modal-icon mx-auto mt-2">
                    <i class="bi bi-exclamation-triangle-fill text-danger fs-1"></i>
                </div>
            </div>
            <div class="modal-body text-center px-5 pt-2 pb-3">
                <h5 class="fw-bold mb-2" id="deleteModalLabel">Delete User?</h5>
                <p class="text-muted mb-1">You are about to permanently delete:</p>
                <p class="fw-semibold text-danger mb-3" id="deleteUserEmail"></p>
                <p class="text-muted small mb-0">This action cannot be undone. All associated data will be removed.</p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-2 pb-4">
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="button" class="btn btn-danger px-4" id="confirmDeleteBtn">
                    <span id="deleteBtnText"><i class="bi bi-trash3 me-1"></i>Yes, Delete</span>
                    <span id="deleteBtnSpinner" class="d-none">
                        <span class="spinner-border spinner-border-sm me-1"></span>Deleting...
                    </span>
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .page-title { font-size: 1.6rem; font-weight: 700; color: #1a1a2e; }
    .avatar-circle {
        width: 38px; height: 38px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 0.9rem; flex-shrink: 0;
    }
    .bg-danger-subtle { background-color: #fff0f0 !important; }
    .bg-primary-subtle { background-color: #eff6ff !important; }
    .table > tbody > tr { transition: background-color 0.15s ease; }
    .table > tbody > tr:hover { background-color: #fafafa; }
    .user-row.d-none { display: none !important; }
    .delete-modal-icon { display: flex; justify-content: center; width: 100%; }
    #deleteToast.bg-success { background-color: #198754 !important; color: #fff; }
    #deleteToast.bg-danger { background-color: #dc3545 !important; color: #fff; }
</style>

@section Scripts {
<script>
    let pendingDeleteId = null;
    const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
    const toast = new bootstrap.Toast(document.getElementById('deleteToast'), { delay: 3500 });

    // Wire delete buttons via data attributes (avoids inline JS encoding issues)
    document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            pendingDeleteId = btn.dataset.userId;
            document.getElementById('deleteUserEmail').textContent = btn.dataset.userEmail;
            deleteModal.show();
        });
    });

    document.getElementById('confirmDeleteBtn').addEventListener('click', async () => {
        if (!pendingDeleteId) return;

        const btn = document.getElementById('confirmDeleteBtn');
        document.getElementById('deleteBtnText').classList.add('d-none');
        document.getElementById('deleteBtnSpinner').classList.remove('d-none');
        btn.disabled = true;

        // Read token at call time, send in body (most reliable for ValidateAntiForgeryToken)
        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        const token = tokenInput ? tokenInput.value : '';

        try {
            const res = await fetch('/IdentityManagement/DeleteUser', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ userId: pendingDeleteId, __RequestVerificationToken: token })
            });

            const data = await res.json();
            deleteModal.hide();

            if (res.ok && data.success) {
                const row = document.getElementById('row-' + pendingDeleteId);
                if (row) {
                    row.style.transition = 'opacity 0.3s ease';
                    row.style.opacity = '0';
                    setTimeout(() => row.remove(), 300);
                }
                showToast('success', '<i class="bi bi-check-circle-fill me-2"></i>' + data.message);
            } else {
                showToast('danger', '<i class="bi bi-exclamation-triangle-fill me-2"></i>' + (data.message || 'Delete failed.'));
            }
        } catch (err) {
            deleteModal.hide();
            showToast('danger', '<i class="bi bi-exclamation-triangle-fill me-2"></i>Network error. Please try again.');
        } finally {
            document.getElementById('deleteBtnText').classList.remove('d-none');
            document.getElementById('deleteBtnSpinner').classList.add('d-none');
            btn.disabled = false;
            pendingDeleteId = null;
        }
    });

    function showToast(type, html) {
        const el = document.getElementById('deleteToast');
        el.className = `toast align-items-center border-0 bg-${type}`;
        document.getElementById('toastBody').innerHTML = html;
        toast.show();
    }

    function filterUsers(query) {
        const q = query.toLowerCase();
        document.querySelectorAll('#usersBody .user-row').forEach(row => {
            const text = row.textContent.toLowerCase();
            row.classList.toggle('d-none', q.length > 0 && !text.includes(q));
        });
    }
</script>
}

@model BloodDonorProject.Models.Donation

@{
    ViewData["Title"] = "Delete Donation";
}

<style>
    .danger-hero {
        background: linear-gradient(135deg, #dc3545 0%, #bb2d3b 100%);
        border-radius: 16px;
        padding: 2rem;
        color: white;
        margin-bottom: 2rem;
    }

    .danger-hero .hero-icon {
        width: 56px;
        height: 56px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        margin-bottom: 1rem;
    }

    .confirm-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .confirm-card-header {
        background: #fff5f5;
        border-bottom: 1px solid #fce8ea;
        padding: 1.25rem 1.75rem;
    }

    .confirm-card-body {
        padding: 1.75rem;
    }

    .detail-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.875rem 1rem;
        border-radius: 10px;
        background: #f8f9fa;
        margin-bottom: 0.75rem;
    }

    .detail-row .detail-icon {
        width: 38px;
        height: 38px;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .detail-label {
        font-size: 0.78rem;
        font-weight: 600;
        color: #adb5bd;
        text-transform: uppercase;
        letter-spacing: 0.4px;
    }

    .detail-value {
        font-size: 0.95rem;
        font-weight: 600;
        color: #212529;
    }

    .warning-box {
        background: #fff8f0;
        border: 1.5px solid #ffc107;
        border-radius: 10px;
        padding: 0.875rem 1rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.875rem;
        color: #856404;
    }

    .btn-delete {
        background: linear-gradient(135deg, #dc3545 0%, #bb2d3b 100%);
        border: none;
        border-radius: 10px;
        padding: 0.75rem 2rem;
        font-weight: 600;
        font-size: 1rem;
        color: white;
        transition: transform 0.15s, box-shadow 0.15s;
    }

    .btn-delete:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(220, 53, 69, 0.35);
        color: white;
    }

    .btn-cancel {
        border-radius: 10px;
        padding: 0.75rem 1.5rem;
        font-weight: 600;
        font-size: 1rem;
        color: #6c757d;
        background: #f8f9fa;
        border: 1.5px solid #dee2e6;
        transition: all 0.15s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }

    .btn-cancel:hover {
        background: #e9ecef;
        color: #495057;
        border-color: #adb5bd;
    }
</style>

<div class="row justify-content-center">
    <div class="col-lg-7 col-xl-6">

        <!-- Hero Banner -->
        <div class="danger-hero">
            <div class="hero-icon">
                <i class="bi bi-trash3-fill"></i>
            </div>
            <h4 class="mb-1" style="font-weight:700;">Delete Donation Record</h4>
            <p class="mb-0 opacity-75 small">Review the record below before confirming deletion.</p>
        </div>

        <!-- Confirm Card -->
        <div class="confirm-card">
            <div class="confirm-card-header d-flex align-items-center gap-2">
                <i class="bi bi-exclamation-triangle-fill text-danger"></i>
                <span style="font-weight:600;">Record to be Deleted</span>
            </div>

            <div class="confirm-card-body">

                <!-- Warning -->
                <div class="warning-box">
                    <i class="bi bi-exclamation-circle-fill text-warning fs-5"></i>
                    <span>This action is <strong>permanent</strong> and cannot be undone.</span>
                </div>

                <!-- Record Details -->
                <div class="mb-4">
                    <div class="detail-row">
                        <div class="detail-icon bg-danger bg-opacity-10">
                            <i class="bi bi-person-fill text-danger"></i>
                        </div>
                        <div>
                            <div class="detail-label">Donor</div>
                            <div class="detail-value">@Model.BloodDonor?.FullName</div>
                        </div>
                    </div>

                    <div class="detail-row">
                        <div class="detail-icon bg-danger bg-opacity-10">
                            <i class="bi bi-calendar-event text-danger"></i>
                        </div>
                        <div>
                            <div class="detail-label">Donation Date</div>
                            <div class="detail-value">@Model.DonationDate.ToString("MMMM dd, yyyy")</div>
                        </div>
                    </div>

                    <div class="detail-row">
                        <div class="detail-icon bg-danger bg-opacity-10">
                            <i class="bi bi-droplet-fill text-danger"></i>
                        </div>
                        <div>
                            <div class="detail-label">Blood Group</div>
                            <div class="detail-value">
                                <span class="badge bg-danger px-3 py-2 rounded-pill">
                                    @Model.BloodDonor?.BloodGroup.ToString().Replace("_Positive", "+").Replace("_Negative", "-")
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-delete flex-fill">
                            <i class="bi bi-trash3 me-2"></i>Yes, Delete
                        </button>
                        <a asp-action="Index" class="btn-cancel">
                            <i class="bi bi-x-lg"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

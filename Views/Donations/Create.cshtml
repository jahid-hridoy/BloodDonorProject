@model BloodDonorProject.Models.Donation

@{
    ViewData["Title"] = "Record Donation";
}

<style>
    .donation-hero {
        background: linear-gradient(135deg, #dc3545 0%, #bb2d3b 100%);
        border-radius: 16px;
        padding: 2rem;
        color: white;
        margin-bottom: 2rem;
    }

    .donation-hero .hero-icon {
        width: 56px;
        height: 56px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        margin-bottom: 1rem;
    }

    .form-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .form-card-header {
        background: #f8f9fa;
        border-bottom: 1px solid #e9ecef;
        padding: 1.25rem 1.75rem;
    }

    .form-card-body {
        padding: 1.75rem;
    }

    .field-label {
        font-weight: 600;
        font-size: 0.875rem;
        color: #495057;
        margin-bottom: 0.5rem;
    }

    .form-control, .form-select {
        border: 1.5px solid #dee2e6;
        border-radius: 10px;
        padding: 0.625rem 0.875rem;
        font-size: 0.95rem;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .form-control:focus, .form-select:focus {
        border-color: #dc3545;
        box-shadow: 0 0 0 3px rgba(220, 53, 69, 0.12);
    }

    .input-icon-wrap {
        position: relative;
    }

    .input-icon-wrap .bi {
        position: absolute;
        left: 0.875rem;
        top: 50%;
        transform: translateY(-50%);
        color: #adb5bd;
        font-size: 1rem;
        pointer-events: none;
    }

    .input-icon-wrap .form-control,
    .input-icon-wrap .form-select {
        padding-left: 2.5rem;
    }

    .btn-submit {
        background: linear-gradient(135deg, #dc3545 0%, #bb2d3b 100%);
        border: none;
        border-radius: 10px;
        padding: 0.75rem 2rem;
        font-weight: 600;
        font-size: 1rem;
        letter-spacing: 0.3px;
        transition: transform 0.15s, box-shadow 0.15s;
        color: white;
    }

    .btn-submit:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(220, 53, 69, 0.35);
        color: white;
    }

    .btn-submit:active {
        transform: translateY(0);
    }

    .btn-back {
        border-radius: 10px;
        padding: 0.75rem 1.5rem;
        font-weight: 600;
        font-size: 1rem;
        color: #6c757d;
        background: #f8f9fa;
        border: 1.5px solid #dee2e6;
        transition: all 0.15s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }

    .btn-back:hover {
        background: #e9ecef;
        color: #495057;
        border-color: #adb5bd;
    }

    .step-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(220, 53, 69, 0.1);
        color: #dc3545;
        border-radius: 20px;
        padding: 0.25rem 0.875rem;
        font-size: 0.8rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
    }
</style>

<div class="row justify-content-center">
    <div class="col-lg-7 col-xl-6">

        <!-- Hero Banner -->
        <div class="donation-hero">
            <div class="hero-icon">
                <i class="bi bi-droplet-fill"></i>
            </div>
            <h4 class="fw-700 mb-1" style="font-weight:700;">Record New Donation</h4>
            <p class="mb-0 opacity-75 small">Log a blood donation by selecting a donor and date.</p>
        </div>

        <!-- Form Card -->
        <div class="form-card">
            <div class="form-card-header d-flex align-items-center gap-2">
                <i class="bi bi-clipboard2-heart text-danger"></i>
                <span class="fw-600" style="font-weight:600;">Donation Details</span>
            </div>

            <div class="form-card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small rounded-3 mb-3" role="alert"></div>

                    <!-- Donation Date -->
                    <div class="mb-4">
                        <label asp-for="DonationDate" class="field-label">
                            <i class="bi bi-calendar3 text-danger me-1"></i>Donation Date
                        </label>
                        <div class="input-icon-wrap">
                            <i class="bi bi-calendar-event"></i>
                            <input asp-for="DonationDate" class="form-control" type="date" />
                        </div>
                        <span asp-validation-for="DonationDate" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <!-- Donor Selector -->
                    <div class="mb-4">
                        <label asp-for="BloodDonorId" class="field-label">
                            <i class="bi bi-person-heart text-danger me-1"></i>Select Donor
                        </label>
                        <div class="input-icon-wrap">
                            <i class="bi bi-person"></i>
                            <select asp-for="BloodDonorId" class="form-select" asp-items="ViewBag.donorList">
                                <option value="">-- Select Donor --</option>
                            </select>
                        </div>
                        <span asp-validation-for="BloodDonorId" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <!-- Actions -->
                    <div class="d-flex gap-3 pt-2">
                        <button type="submit" class="btn btn-submit flex-fill">
                            <i class="bi bi-check2-circle me-2"></i>Record Donation
                        </button>
                        <a asp-action="Index" class="btn-back">
                            <i class="bi bi-arrow-left"></i>Back
                        </a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@using Microsoft.Build.Construction
@model List<BloodDonorListViewModel>

@{
    ViewData["Title"] = "Blood Donor Directory";
}

<div class="container mt-4">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-danger">🩸 Blood Donor Directory</h2>
            <p class="text-muted mb-0">Find and manage registered blood donors</p>
        </div>

        <a asp-action="Create" class="btn btn-danger px-4">
            + Add New Donor
        </a>
    </div>

    <!-- Search Panel -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Blood Group</label>
                    <select name="bloodGroup" class="form-select">
                        <option value="">All</option>
                        @foreach (var bg in Enum.GetNames(typeof(BloodGroup)))
                        {
                            <option value="@bg">@bg.Replace("_Positive", "+").Replace("_Negative", "-")</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Address</label>
                    <input type="text" name="address" class="form-control" placeholder="Search by area">
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Eligibility</label>
                    <select name="eligible" class="form-select">
                        <option value="">All</option>
                        <option value="true">Eligible</option>
                        <option value="false">Not Eligible</option>
                    </select>
                </div>

                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-danger w-100">
                       Search
                    </button>
                </div>

            </form>
        </div>
    </div>

    <!-- Donor Table -->
    <div class="card shadow border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-danger text-center">
                    <tr>
                        <th>ID</th>
                        <th>Donor</th>
                        <th>Contact</th>
                        <th>Age</th>
                        <th>Email</th>
                        <th>Blood</th>
                        <th>Address</th>
                        <th>Last Donation</th>
                        <th>Status</th>
                        <th>Photo</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody class="text-center">

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Id</td>
                                <td class="fw-semibold">@item.FullName</td>
                                <td>@item.ContactNumber</td>
                                <td>@item.Age</td>
                                <td>@item.Email</td>
                                <td>
                                    <span class="badge bg-danger fs-6">
                                        @item.BloodGroup.ToString().Replace("_Positive", "+").Replace("_Negative", "-")
                                    </span>
                                </td>
                                <td>@item.Address</td>
                                <td>@item.LastDonationDate</td>
                                <td>
                                    @if (item.IsEligibleForDonation)
                                    {
                                        <span class="badge bg-success">Eligible</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Not Eligible</span>
                                    }
                                </td>
                                <td>
                                    <img src="@(string.IsNullOrEmpty(item.ProfilePicture) ? "/ProfilePictures/profile-icon.png" : item.ProfilePicture)"
                                         class="rounded-circle border"
                                         style="width:45px;height:45px;object-fit:cover">
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">View</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="11" class="py-4 text-muted">
                                No donors found.
                            </td>
                        </tr>
                    }

                </tbody>
            </table>
        </div>
    </div>
</div>
